{
  "name": "ttarot",
  "version": "0.1.0",
  "description": "A mystical tarot reading experience for the terminal",
  "author": "gfargo <ghfargo@gmail.com>",
  "license": "MIT",
  "bin": "dist/cli.js",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node dist/cli.js",
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "release": "release-it",
    "lint": "prettier --check . && xo",
    "lint:fix": "prettier --write . && xo --fix",
    "test": "ava",
    "test:fix": "yarn lint:fix && ava --update-snapshots"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "ink": "^6.8.0",
    "ink-playing-cards": "^1.1.0",
    "meow": "^14.1.0",
    "react": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.8.2",
    "@types/react": "^19.1.0",
    "ava": "^6.2.0",
    "chalk": "^5.4.0",
    "eslint-config-xo-react": "^0.27.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.4.0",
    "release-it": "^17.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "xo": "^0.59.3"
  },
  "ava": {
    "workerThreads": false,
    "extensions": {
      "ts": "module",
      "tsx": "module"
    },
    "nodeArguments": [
      "--import=tsx"
    ]
  },
  "xo": {
    "extends": "xo-react",
    "prettier": true,
    "rules": {
      "react/prop-types": "off",
      "react/no-array-index-key": "off",
      "unicorn/filename-case": "off",
      "@typescript-eslint/ban-ts-comment": "off",
      "@typescript-eslint/naming-convention": [
        "error",
        {
          "selector": "variable",
          "format": [
            "camelCase",
            "PascalCase",
            "UPPER_CASE"
          ]
        }
      ]
    }
  }
}
